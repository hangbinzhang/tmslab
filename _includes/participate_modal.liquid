{%- comment -%}
  "Participate in a Study" modal. The form itself is a Microsoft
  Forms response page embedded via <iframe>; this modal only
  provides the branded wrapper + intro/note copy around it.

  Triggers: any element with `data-tmslab-open-modal="participate"`.
  Closes on: backdrop click, [data-modal-close] click, or Escape key.
{%- endcomment -%}

<div
  id="tmslab-participate-modal"
  class="tmslab-modal"
  aria-hidden="true"
  role="dialog"
  aria-labelledby="tmslab-participate-title"
  aria-modal="true"
>
  <div class="tmslab-modal-backdrop" data-modal-close></div>

  <div class="tmslab-modal-card" role="document">
    <button class="tmslab-modal-close" type="button" data-modal-close aria-label="Close dialog">&times;</button>

    <h2 id="tmslab-participate-title">Participate in a Study</h2>

    <p class="tmslab-modal-intro">
      Interested in taking part in our research? Fill out the form below and our team will reach out with details about eligibility and scheduling.
    </p>

    <div class="tmslab-embed-wrap tmslab-embed-wrap--modal">
      <iframe
        src="https://forms.office.com/Pages/ResponsePage.aspx?id=BVXjXo7rKUmTfWRd9QEyiPL1skBrvjpLpZ4PYOiQ35pUNEpENzY5MVpCQ0JOMzNBWlY4VFVXS1JaSi4u&embed=true"
        title="Study interest form"
        frameborder="0"
        marginwidth="0"
        marginheight="0"
        allowfullscreen
        webkitallowfullscreen
        mozallowfullscreen
        msallowfullscreen
        loading="lazy">
      </iframe>
    </div>

    <p class="tmslab-modal-note">
      Your information will be used only to contact you about study participation. We do not share contact information with third parties.
    </p>
  </div>
</div>
